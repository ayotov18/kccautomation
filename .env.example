# ── Database ──
DATABASE_URL=postgres://kcc:kcc_dev_password@localhost:5432/kcc

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── AWS S3 ──
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=kcc-files-dev
# AWS_ENDPOINT_URL=  # Set only for MinIO / local dev

# ── BrightData (web unlocker) ──
BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE=web_unlocker1

# ── LLM ──
OPENROUTER_API_KEY=

# ── Auth ──
JWT_SECRET=change-me-minimum-32-characters-long

# ── Runtime ──
RUST_LOG=info,kcc_core=debug,kcc_api=debug,kcc_worker=debug
API_HOST=0.0.0.0
API_PORT=3000
